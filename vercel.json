{
  "buildCommand": "pip install -r requirements.txt",
  "framework": "streamlit",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app.py"
    }
  ],
  "functions": {
    "app.py": {
      "runtime": "python3.12"
    }
  },
  "env": {
    "STREAMLIT_SERVER_PORT": "3000",
    "STREAMLIT_SERVER_ADDRESS": "0.0.0.0",
    "STREAMLIT_SERVER_HEADLESS": "true"
  }
}
